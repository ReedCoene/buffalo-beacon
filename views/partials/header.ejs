<header>
  <a href="/" class="logo" aria-label="Buffalo Beacon home">
    <span class="logo-mark" aria-hidden="true">
      <svg viewBox="0 0 32 32" width="30" height="30"><circle cx="16" cy="16" r="15" fill="#081a33"/><circle cx="16" cy="13" r="6" fill="#ffb703"/><path d="M10 22h12l-2 6h-8z" fill="#ffb703" opacity=".55"/></svg>
    </span>
    <h1>Buffalo <span>Beacon</span></h1>
  </a>
  <nav class="header-nav">
    <% if (typeof org !== 'undefined' && org) { %>
      <span class="signed-in">Signed in as <strong><%= org.name %></strong></span>
      <form method="post" action="/logout"><button class="secondary small" type="submit">Log out</button></form>
    <% } else { %>
      <a href="/login" class="nav-link">Organization login</a>
    <% } %>
  </nav>
</header>
