<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Buffalo Beacon — who\'s open right now' }) %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
  <%- include('partials/header') %>

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">Buffalo, NY &middot; Verified live status</p>
      <h2>Find an open door.</h2>
      <p class="hero-sub">Live shelters, food pantries, and warming centers across Buffalo &mdash; when the weather turns dangerous and you need a warm place or a hot meal.</p>
      <div class="hero-stats">
        <% const openCount = orgs.filter(o => o.is_open).length; %>
        <% const verifiedCount = orgs.filter(o => o.verified).length; %>
        <span class="stat"><span class="pulse-dot" aria-hidden="true"></span><strong><%= openCount %></strong>&nbsp;open right now</span>
        <span class="stat"><strong><%= verifiedCount %></strong>&nbsp;verified organization<%= verifiedCount === 1 ? '' : 's' %></span>
        <span class="stat">updated by the orgs themselves</span>
      </div>
    </div>
  </section>

  <main>
    <% if (msg) { %>
      <div class="msg"><%= msg %></div>
    <% } %>

    <div class="map-wrap"><div id="map" aria-label="Map of shelters and pantries"></div></div>

    <% if (orgs.length === 0) { %>
      <p class="empty">No organizations listed yet &mdash; check back soon.</p>
    <% } %>

    <% if (board && board.length) { %>
      <section class="board">
        <h2 class="section-title">Ways to help &amp; what's happening</h2>
        <p class="section-sub">Local orgs are asking for a hand or sharing news. Show up, pitch in, or spread the word.</p>
        <div class="board-list">
          <% board.forEach(p => { %>
            <div class="board-card">
              <span class="board-tag <%= p.kind %>"><%= p.kind === 'need' ? 'Needs help' : 'Update' %></span>
              <p class="board-text"><%= p.body %></p>
              <p class="board-org"><%= p.org_name %><% if (p.org_verified) { %> <span class="verified">&#10003;</span><% } %></p>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (orgs.length) { %>
      <h2 class="section-title">Open shelters &amp; pantries</h2>
      <p class="section-sub">Open places sort to the top. Every <span class="verified">&#10003; Verified</span> badge means Buffalo Beacon vetted the organization itself.</p>
    <% } %>
    <div class="grid">
      <% orgs.forEach(org => { %>
        <article class="card">
          <div class="card-top">
            <span class="badge <%= org.is_open ? 'open' : 'closed' %>">
              <span class="dot" aria-hidden="true"></span><%= org.is_open ? 'Open now' : 'Closed' %>
            </span>
            <% const fresh = timeAgo(org.updated_at); %>
            <% if (fresh) { %><span class="freshness">Updated <%= fresh %></span><% } %>
          </div>
          <h3><%= org.name %><% if (org.verified) { %> <span class="verified" title="Verified by Buffalo Beacon">&#10003; Verified</span><% } %></h3>
          <% if (org.address) { %>
            <p class="addr"><a class="directions" href="<%= mapsLink(org.address) %>" target="_blank" rel="noopener">&#128205; <%= org.address %></a></p>
          <% } %>
          <% if (org.hours_text) { %>
            <p class="hours"><strong>Hours:</strong> <%= org.hours_text %></p>
          <% } %>
          <% if (org.description) { %>
            <p class="desc"><%= org.description %></p>
          <% } %>

          <div class="card-actions">
            <% if (org.address) { %>
              <a class="directions-btn" href="<%= mapsLink(org.address) %>" target="_blank" rel="noopener">Get directions</a>
            <% } %>
            <form class="subscribe-form" method="post" action="/subscribe/<%= org.id %>">
              <input type="email" name="email" placeholder="your email" aria-label="Email for <%= org.name %> updates" required>
              <button type="submit">Get updates</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // <-escaping stops a closing script tag inside an org name from ending this script block
    // (the HTML parser ends a script element on that tag even inside strings or comments)
    const pins = <%- JSON.stringify(pins).replace(/</g, '\\u003c') %>;
    // bindPopup treats strings as HTML, and org name/address are org-typed text — escape them
    const esc = s => String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const map = L.map('map').setView([42.8864, -78.8784], 12); // downtown Buffalo
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 19,
    }).addTo(map);

    const markers = [];
    pins.forEach(p => {
      const color = p.isOpen ? '#1e9e50' : '#7d8698';
      const icon = L.divIcon({
        className: 'beacon-pin',
        html: `<div class="${p.isOpen ? 'pin-open' : ''}" style="background:${color}"></div>`,
        iconSize: [22, 22],
        iconAnchor: [11, 11],
      });
      const m = L.marker([p.lat, p.lng], { icon }).addTo(map);
      m.bindPopup(
        `<strong>${esc(p.name)}</strong><br>${p.isOpen ? '🟢 Open now' : '⚪ Closed'}<br>` +
        `<a href="https://www.google.com/maps/search/?api=1&query=${esc(encodeURIComponent(p.address))}" target="_blank" rel="noopener">Get directions</a>`
      );
      markers.push(m);
    });

    // Zoom to fit all pins if we have any — capped so a single pin doesn't zoom to rooftop level.
    if (markers.length) {
      map.fitBounds(L.featureGroup(markers).getBounds().pad(0.3), { maxZoom: 14 });
    }
  </script>
</body>
</html>
