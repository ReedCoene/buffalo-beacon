<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: '716 Beacon — who\'s open right now' }) %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
  <%- include('partials/header') %>

  <div class="page-head">
    <h2>Who's open right now in Buffalo</h2>
    <p>Live status of shelters, food pantries, and warming centers &mdash; updated directly by the organizations, verified by 716 Beacon.</p>
  </div>

  <% const openCount = orgs.filter(o => o.is_open).length; %>
  <% if (orgs.length === 0) { %>
    <div class="status-bar">Onboarding Buffalo shelters and pantries now &mdash; launching for winter.</div>
  <% } else if (openCount > 0) { %>
    <div class="status-bar some-open"><span class="count"><%= openCount %> open now</span> &middot; <%= orgs.length %> verified organization<%= orgs.length === 1 ? '' : 's' %> listed</div>
  <% } else { %>
    <div class="status-bar">Nothing open right now &middot; <%= orgs.length %> verified organization<%= orgs.length === 1 ? '' : 's' %> listed</div>
  <% } %>

  <main>
    <% if (msg) { %>
      <div class="msg"><%= msg %></div>
    <% } %>

    <div class="map-wrap"><div id="map" aria-label="Map of shelters and pantries"></div></div>

    <% if (orgs.length === 0) { %>
      <section class="board">
        <h2 class="section-title">Here's what it will look like</h2>
        <p class="section-sub">We're onboarding Buffalo's shelters and pantries now. Once an organization is verified, its live status appears here &mdash; like this:</p>
        <div class="grid">
          <article class="card demo is-open" aria-label="Sample listing — not a real organization">
            <div class="card-top">
              <span class="badge open"><span class="dot" aria-hidden="true"></span>Open now</span>
              <span class="demo-tag">Sample</span>
            </div>
            <h3>Example Warming Center <span class="verified">&#10003; Verified</span></h3>
            <p class="addr">123 Main St, Buffalo, NY</p>
            <p class="hours"><strong>Hours:</strong> Tonight 6pm&ndash;8am</p>
            <p class="desc">Warm beds, hot coffee, and a safe place to wait out the storm. Walk-ins welcome.</p>
            <div class="card-actions">
              <a class="directions-btn" href="/login">Run a shelter? Get listed</a>
            </div>
          </article>
          <article class="card demo" aria-label="Sample listing — not a real organization">
            <div class="card-top">
              <span class="badge closed"><span class="dot" aria-hidden="true"></span>Closed</span>
              <span class="demo-tag">Sample</span>
            </div>
            <h3>Example Food Pantry <span class="verified">&#10003; Verified</span></h3>
            <p class="addr">456 Elmwood Ave, Buffalo, NY</p>
            <p class="hours"><strong>Hours:</strong> Saturdays 9am&ndash;1pm</p>
            <p class="desc">Groceries and hot meals every Saturday morning &mdash; no questions, no paperwork.</p>
            <div class="card-actions">
              <a class="directions-btn" href="/login">Run a pantry? Get listed</a>
            </div>
          </article>
        </div>
      </section>
    <% } %>

    <% if (board && board.length) { %>
      <section class="board">
        <h2 class="section-title">Ways to help &amp; what's happening</h2>
        <p class="section-sub">Local orgs are asking for a hand or sharing news. Show up, pitch in, or spread the word.</p>
        <div class="board-list">
          <% board.forEach(p => { %>
            <div class="board-card">
              <span class="board-tag <%= p.kind %>"><%= p.kind === 'need' ? 'Needs help' : 'Update' %></span>
              <p class="board-text"><%= p.body %></p>
              <p class="board-org"><%= p.org_name %><% if (p.org_verified) { %> <span class="verified">&#10003;</span><% } %></p>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (orgs.length) { %>
      <h2 class="section-title">Open shelters &amp; pantries</h2>
      <p class="section-sub">Open places sort to the top. Every <span class="verified">&#10003; Verified</span> badge means 716 Beacon vetted the organization itself.</p>
    <% } %>
    <div class="grid">
      <% orgs.forEach(org => { %>
        <article class="card <%= org.is_open ? 'is-open' : '' %>">
          <div class="card-top">
            <span class="badge <%= org.is_open ? 'open' : 'closed' %>">
              <span class="dot" aria-hidden="true"></span><%= org.is_open ? 'Open now' : 'Closed' %>
            </span>
            <% const fresh = timeAgo(org.updated_at); %>
            <% if (fresh) { %><span class="freshness">Updated <%= fresh %></span><% } %>
          </div>
          <h3><%= org.name %><% if (org.verified) { %> <span class="verified" title="Verified by 716 Beacon">&#10003; Verified</span><% } %></h3>
          <% if (org.address) { %>
            <p class="addr"><a class="directions" href="<%= mapsLink(org.address) %>" target="_blank" rel="noopener"><%= org.address %></a></p>
          <% } %>
          <% if (org.hours_text) { %>
            <p class="hours"><strong>Hours:</strong> <%= org.hours_text %></p>
          <% } %>
          <% if (org.description) { %>
            <p class="desc"><%= org.description %></p>
          <% } %>

          <div class="card-actions">
            <% if (org.address) { %>
              <a class="directions-btn" href="<%= mapsLink(org.address) %>" target="_blank" rel="noopener">Get directions</a>
            <% } %>
            <form class="subscribe-form" method="post" action="/subscribe/<%= org.id %>">
              <input type="email" name="email" placeholder="your email" aria-label="Email for <%= org.name %> updates" required>
              <button type="submit">Get updates</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // <-escaping stops a closing script tag inside an org name from ending this script block
    // (the HTML parser ends a script element on that tag even inside strings or comments)
    const pins = <%- JSON.stringify(pins).replace(/</g, '\\u003c') %>;
    // bindPopup treats strings as HTML, and org name/address are org-typed text — escape them
    const esc = s => String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const map = L.map('map').setView([42.8864, -78.8784], 12); // downtown Buffalo
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 19,
    }).addTo(map);

    const markers = [];
    pins.forEach(p => {
      const color = p.isOpen ? '#157f3d' : '#5f6b7a';
      const icon = L.divIcon({
        className: 'beacon-pin',
        html: `<div class="${p.isOpen ? 'pin-open' : ''}" style="background:${color}"></div>`,
        iconSize: [22, 22],
        iconAnchor: [11, 11],
      });
      const m = L.marker([p.lat, p.lng], { icon }).addTo(map);
      m.bindPopup(
        `<strong>${esc(p.name)}</strong><br>${p.isOpen ? 'Open now' : 'Closed'}<br>` +
        `<a href="https://www.google.com/maps/search/?api=1&query=${esc(encodeURIComponent(p.address))}" target="_blank" rel="noopener">Get directions</a>`
      );
      markers.push(m);
    });

    // Zoom to fit all pins if we have any — capped so a single pin doesn't zoom to rooftop level.
    if (markers.length) {
      map.fitBounds(L.featureGroup(markers).getBounds().pad(0.3), { maxZoom: 14 });
    }
  </script>
</body>
</html>
