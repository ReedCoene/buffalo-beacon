<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: org.name + ' — Buffalo Beacon dashboard' }) %>
</head>
<body>
  <%- include('partials/header', { org }) %>

  <main class="dash">
    <h2 class="page-title"><%= org.name %></h2>
    <p class="page-sub">
      Everything you save here publishes instantly to the public page<% if (timeAgo(org.updated_at)) { %> &middot; last updated <%= timeAgo(org.updated_at) %><% } %>.
    </p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="msg">
        Saved &mdash; your public page is updated<% if (typeof notified !== 'undefined' && notified) { %> and subscribers were emailed<% } %>.
        <% if (typeof tweetUrl !== 'undefined' && tweetUrl) { %>
          <div style="margin-top:10px;">
            <a class="tweet-btn" href="<%= tweetUrl %>" target="_blank" rel="noopener">Post this update to X / Twitter</a>
            <span class="tweet-hint">Opens X with your update pre-written &mdash; just click Post.</span>
          </div>
        <% } %>
      </div>
    <% } %>

    <div class="panel">
      <h3>Your public listing</h3>
      <p class="panel-sub">This is what neighbors, families, and 211 operators see. Keep it current &mdash; especially the open/closed switch.</p>

      <form method="post" action="/dashboard/update">
        <div class="field">
          <label class="switch">
            <input type="checkbox" id="is_open" name="is_open" <%= org.is_open ? 'checked' : '' %>>
            <span class="track" aria-hidden="true"></span>
            <span class="switch-label">We are open right now</span>
          </label>
          <p class="hint">Flipping this emails everyone subscribed to you &mdash; that's the point. Flip it the moment you open or close.</p>
        </div>

        <div class="field">
          <label for="name">Organization name *</label>
          <input type="text" id="name" name="name" value="<%= org.name %>" required>
        </div>

        <div class="field">
          <label for="address">Address *</label>
          <input type="text" id="address" name="address" value="<%= org.address %>" required>
        </div>

        <div class="field">
          <label for="hours_text">Hours *</label>
          <input type="text" id="hours_text" name="hours_text" value="<%= org.hours_text %>" placeholder="e.g. Today 9am-3pm" required>
        </div>

        <div class="field">
          <label for="description">Description</label>
          <textarea id="description" name="description" placeholder="A rough note is fine — e.g. 'open 9-3 today, hot food, giving away toiletries' — then let AI polish it."><%= org.description %></textarea>
          <button type="button" class="secondary small" id="improveBtn" style="margin-top:10px;">&#10024; Improve with AI</button>
          <div class="ai-preview" id="aiPreview">
            <p class="ai-preview-label">AI suggestion &mdash; you decide</p>
            <div id="aiPreviewText"></div>
            <div style="margin-top:10px;">
              <button type="button" class="small" id="useAi">Use this</button>
              <button type="button" class="secondary small" id="discardAi">Keep my original</button>
            </div>
          </div>
        </div>

        <button type="submit">Save &amp; publish</button>
      </form>
    </div>

    <div class="panel">
      <h3>Community board</h3>
      <p class="panel-sub">Post a <strong>need</strong> (volunteers, donations) or an <strong>update</strong> (an event, an announcement). These show up publicly so neighbors can help or show up.</p>

      <form method="post" action="/dashboard/post">
        <div class="field">
          <label for="kind">Type</label>
          <select id="kind" name="kind">
            <option value="need">&#128587; Need help (volunteers / donations)</option>
            <option value="update">&#128226; Update / event</option>
          </select>
        </div>
        <div class="field">
          <label for="body">Message</label>
          <textarea id="body" name="body" placeholder="e.g. We need 4 volunteers Saturday 8am to sort coat donations — walk-ins welcome!" required></textarea>
        </div>
        <button type="submit">Post to board</button>
      </form>

      <% if (posts && posts.length) { %>
        <h4>Your posts</h4>
        <% posts.forEach(p => { %>
          <div class="board-item">
            <span class="board-tag <%= p.kind %>"><%= p.kind === 'need' ? 'Need' : 'Update' %></span>
            <span class="board-body"><%= p.body %></span>
            <form method="post" action="/dashboard/post/<%= p.id %>/delete" style="display:inline;">
              <button type="submit" class="link-btn" title="Delete">Remove</button>
            </form>
          </div>
        <% }) %>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    const improveBtn = document.getElementById('improveBtn');
    const preview = document.getElementById('aiPreview');
    const previewText = document.getElementById('aiPreviewText');
    const description = document.getElementById('description');
    let originalBeforeAi = null;

    improveBtn.addEventListener('click', async () => {
      improveBtn.disabled = true;
      improveBtn.textContent = 'Improving...';
      try {
        const res = await fetch('/dashboard/improve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: description.value }),
        });
        const data = await res.json();
        originalBeforeAi = description.value;
        previewText.textContent = data.improved;
        preview.style.display = 'block';
      } finally {
        improveBtn.disabled = false;
        improveBtn.textContent = '✨ Improve with AI';
      }
    });

    document.getElementById('useAi').addEventListener('click', () => {
      description.value = previewText.textContent;
      preview.style.display = 'none';
    });

    document.getElementById('discardAi').addEventListener('click', () => {
      preview.style.display = 'none';
    });
  </script>
</body>
</html>
