<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Organization login — Buffalo Beacon' }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="narrow">
    <% if (msg) { %>
      <div class="msg"><%= msg %></div>
    <% } %>

    <div class="panel">
      <% if (sent) { %>
        <h3>Check your email</h3>
        <p>If that email has a Buffalo Beacon account, a login link is on its way. It expires in 15 minutes.</p>
        <p class="hint">Nothing arriving? Check spam, or request a new link.</p>
      <% } else { %>
        <h3>Organization login</h3>
        <p class="panel-sub">Accounts are set up by the Buffalo Beacon team &mdash; that's how every listing stays verified. Enter your registered email for a one-click login link. No password needed.</p>
        <form method="post" action="/login">
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@yourorganization.org" required>
          </div>
          <button type="submit">Send login link</button>
        </form>
        <p class="hint" style="margin-top:16px;">Run a shelter, pantry, or warming center that isn't listed yet? Email us and we'll get you verified and onboarded.</p>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
