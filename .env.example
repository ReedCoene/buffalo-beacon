PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-to-something-random

# Your own email — `npm run seed` gives the first demo org this login so you
# can test the whole login → update → notify loop yourself.
SEED_TEST_EMAIL=

# Optional: without this, the AI "improve description" button just returns
# the org's original text unchanged (no crash, just no polish).
ANTHROPIC_API_KEY=

# Optional: without this, emails (magic login links, subscriber notices)
# print to the terminal instead of actually sending. Fine for local testing.
RESEND_API_KEY=
RESEND_FROM=Buffalo Beacon <onboarding@resend.dev>
